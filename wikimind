#!/usr/bin/env bash
# wikimind — CLI for WikiMind knowledge base management
# Usage:
#   wikimind init [PATH]           Create a new wiki at PATH (default: ~/Documents/wiki)
#   wikimind init [PATH] --adopt   Adopt an existing Markdown directory as a wiki
#   wikimind status                Show wiki status and watcher state
#   wikimind start                 Start the auto-sync watcher
#   wikimind stop                  Stop the watcher
#   wikimind index                 Rebuild the full search index

set -euo pipefail

# ── Resolve WIKIMIND_ROOT ──────────────────────────────────────────────────────
_resolve_root() {
    if [[ -n "${WIKIMIND_ROOT:-}" ]]; then
        echo "$WIKIMIND_ROOT"
        return
    fi
    local default="$HOME/Documents/wiki"
    local legacy="$HOME/Documents/知识库"
    if [[ ! -d "$default" && -d "$legacy" ]]; then
        echo "$legacy"
    else
        echo "$default"
    fi
}

WIKI_ROOT="$(_resolve_root)"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
MCP_DIR="$SCRIPT_DIR/.wiki-mcp"

# ── Colors ─────────────────────────────────────────────────────────────────────
GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; RED='\033[0;31m'; NC='\033[0m'
info()    { echo -e "${CYAN}→${NC} $*"; }
success() { echo -e "${GREEN}✓${NC} $*"; }
warn()    { echo -e "${YELLOW}!${NC} $*"; }
error()   { echo -e "${RED}✗${NC} $*" >&2; }
header()  { echo -e "\n${CYAN}$*${NC}"; }

# ── Helpers ────────────────────────────────────────────────────────────────────
check_qmd() {
    if ! command -v qmd &>/dev/null; then
        warn "qmd not found. Install it with: pip3 install qmd"
        warn "Search indexing will be unavailable until qmd is installed."
        return 1
    fi
    return 0
}

watcher_pidfile() {
    echo "$MCP_DIR/watcher.pid"
}

watcher_running() {
    local pidfile
    pidfile="$(watcher_pidfile)"
    if [[ -f "$pidfile" ]]; then
        local pid
        pid=$(cat "$pidfile")
        kill -0 "$pid" 2>/dev/null
    else
        return 1
    fi
}

# ── cmd: init ─────────────────────────────────────────────────────────────────
cmd_init() {
    local target="${1:-}"
    local adopt=false

    # Parse args
    for arg in "$@"; do
        case "$arg" in
            --adopt) adopt=true ;;
            -*) error "Unknown option: $arg"; exit 1 ;;
            *)  [[ -z "$target" || "$target" == "$arg" ]] && target="$arg" ;;
        esac
    done

    # If no path given, ask interactively
    if [[ -z "$target" || "$target" == "--adopt" ]]; then
        echo ""
        echo "Where should WikiMind store your knowledge base?"
        echo "  Press Enter to use the default: $WIKI_ROOT"
        echo -n "  Path: "
        read -r user_input
        target="${user_input:-$WIKI_ROOT}"
    fi

    target="${target/#\~/$HOME}"   # expand ~
    target="$(cd "$(dirname "$target")" 2>/dev/null && pwd)/$(basename "$target")" 2>/dev/null || target="$target"

    # Detect if directory already has content
    if [[ -d "$target" ]] && [[ -n "$(ls -A "$target" 2>/dev/null)" ]] && [[ "$adopt" == false ]]; then
        echo ""
        warn "Directory already exists and is not empty: $target"
        echo "  (a) Adopt it — scan existing subdirectories and set them up as wiki domains"
        echo "  (n) Cancel"
        echo -n "  Choice [a/n]: "
        read -r choice
        case "$choice" in
            a|A|adopt) adopt=true ;;
            *) info "Cancelled."; exit 0 ;;
        esac
    fi

    if [[ "$adopt" == true ]]; then
        _init_adopt "$target"
    else
        _init_new "$target"
    fi
}

_init_new() {
    local target="$1"
    header "Creating new WikiMind knowledge base"
    info "Location: $target"
    echo ""

    mkdir -p "$target"

    # Copy CLAUDE.md
    if [[ -f "$SCRIPT_DIR/CLAUDE.md" ]]; then
        cp "$SCRIPT_DIR/CLAUDE.md" "$target/CLAUDE.md"
        success "Copied CLAUDE.md (AI operating instructions)"
    fi

    # Copy .wiki-mcp
    if [[ -d "$MCP_DIR" ]]; then
        cp -r "$MCP_DIR" "$target/.wiki-mcp"
        success "Copied .wiki-mcp/ (MCP server + watcher)"
    fi

    # Create starter domain
    local domain_dir="$target/my-first-domain"
    mkdir -p "$domain_dir/concepts" "$domain_dir/entities" "$domain_dir/comparisons" "$domain_dir/sources" "$domain_dir/refs"

    cat > "$domain_dir/DOMAIN.md" <<'EOF'
---
title: "My First Domain"
keywords: [replace, these, with, your, own, keywords]
---

# My First Domain

Replace this with a description of what this domain covers.

## Key Concepts

| Concept | Description | See |
|---------|-------------|-----|
| Example | Brief description | `concepts/example.md` |

## Directory Layout

| Directory | Contents |
|-----------|----------|
| `concepts/` | How/why explanations |
| `entities/` | API objects, classes, data structures |
| `comparisons/` | Side-by-side analysis |
| `sources/` | Article and doc summaries |
| `refs/` | Raw reference docs (bulk import, read-only) |
EOF
    success "Created starter domain: my-first-domain/"

    _finalize_init "$target"
}

_init_adopt() {
    local target="$1"
    header "Adopting existing directory as WikiMind knowledge base"
    info "Location: $target"
    echo ""

    mkdir -p "$target"

    # Copy CLAUDE.md
    if [[ -f "$SCRIPT_DIR/CLAUDE.md" ]]; then
        cp "$SCRIPT_DIR/CLAUDE.md" "$target/CLAUDE.md"
        success "Copied CLAUDE.md"
    fi

    # Copy .wiki-mcp
    if [[ -d "$MCP_DIR" ]]; then
        cp -r "$MCP_DIR" "$target/.wiki-mcp"
        success "Copied .wiki-mcp/"
    fi

    # Scan subdirectories — create DOMAIN.md for any that don't have one
    local adopted=0
    local skipped=0
    for subdir in "$target"/*/; do
        [[ -d "$subdir" ]] || continue
        local name
        name="$(basename "$subdir")"
        # Skip hidden dirs and .wiki-mcp
        [[ "$name" == .* ]] && continue

        if [[ -f "$subdir/DOMAIN.md" ]]; then
            info "  $name/ — already has DOMAIN.md, skipping"
            ((skipped++)) || true
        else
            # Auto-generate keywords from directory name
            local kw
            kw=$(echo "$name" | tr '-_' ' ' | tr '[:upper:]' '[:lower:]')
            local kw_list
            kw_list=$(echo "$kw" | tr ' ' '\n' | awk '{printf "\"%s\", ", $0}' | sed 's/, $//')

            cat > "$subdir/DOMAIN.md" <<EOF
---
title: "$name"
keywords: [$kw_list]
---

# $name

Auto-generated by \`wikimind init --adopt\`. Edit this file to:
1. Update the \`keywords\` list — these trigger the AI to search this domain
2. Add a description of what this domain covers

EOF
            success "  $name/ — created DOMAIN.md (keywords: $kw)"
            ((adopted++)) || true
        fi
    done

    echo ""
    info "Adopted $adopted domain(s), skipped $skipped (already configured)"

    _finalize_init "$target"
}

_finalize_init() {
    local target="$1"
    echo ""

    # Build qmd index
    if check_qmd; then
        info "Building search index..."
        (cd "$target" && qmd index . . 2>&1 | tail -3) || warn "Index build had warnings (non-fatal)"
        success "Search index built"
    fi

    # Export WIKIMIND_ROOT hint
    echo ""
    header "Next steps"
    echo ""
    echo "  1. Set your wiki path (add to ~/.zshrc or ~/.bashrc):"
    echo ""
    echo "       export WIKIMIND_ROOT=\"$target\""
    echo ""
    echo "  2. Register the MCP server in your AI client:"
    echo ""
    echo "     Claude Desktop — add to ~/Library/Application Support/Claude/claude_desktop_config.json:"
    echo '     {'
    echo '       "mcpServers": {'
    echo '         "wiki-kb": {'
    echo '           "command": "python3",'
    echo "           \"args\": [\"$target/.wiki-mcp/server.py\"],"
    echo "           \"env\": { \"WIKIMIND_ROOT\": \"$target\" }"
    echo '         }'
    echo '       }'
    echo '     }'
    echo ""
    echo "     CatDesk / OpenClaw:"
    echo "       catdesk mcp add --name wiki-kb --json '{"
    echo "         \"command\": \"python3\","
    echo "         \"args\": [\"$target/.wiki-mcp/server.py\"],"
    echo "         \"env\": {\"WIKIMIND_ROOT\": \"$target\"}"
    echo "       }'"
    echo ""
    echo "  3. Start the auto-sync watcher:"
    echo ""
    echo "       wikimind start"
    echo ""
    echo "     Auto-start on login:"
    echo "       echo 'wikimind start > /dev/null 2>&1' >> ~/.zshrc"
    echo ""
    success "WikiMind initialized at: $target"
}

# ── cmd: start ────────────────────────────────────────────────────────────────
cmd_start() {
    local pidfile
    pidfile="$(watcher_pidfile)"
    local logfile="$MCP_DIR/watcher.log"

    if watcher_running; then
        local pid
        pid=$(cat "$pidfile")
        success "Watcher already running (pid $pid)"
        return 0
    fi

    if [[ ! -f "$MCP_DIR/watcher.py" ]]; then
        error "watcher.py not found at $MCP_DIR/watcher.py"
        error "Run 'wikimind init' first."
        exit 1
    fi

    WIKIMIND_ROOT="$WIKI_ROOT" nohup python3 "$MCP_DIR/watcher.py" >> "$logfile" 2>&1 &
    local pid=$!
    echo "$pid" > "$pidfile"
    success "Watcher started (pid $pid)"
    info "Watching: $WIKI_ROOT"
    info "Log: $logfile"
}

# ── cmd: stop ─────────────────────────────────────────────────────────────────
cmd_stop() {
    local pidfile
    pidfile="$(watcher_pidfile)"

    if ! watcher_running; then
        info "Watcher is not running."
        return 0
    fi

    local pid
    pid=$(cat "$pidfile")
    kill "$pid" 2>/dev/null && success "Watcher stopped (pid $pid)" || warn "Could not stop pid $pid"
    rm -f "$pidfile"
}

# ── cmd: status ───────────────────────────────────────────────────────────────
cmd_status() {
    header "WikiMind Status"
    echo ""
    info "Wiki root:  $WIKI_ROOT"

    if [[ -d "$WIKI_ROOT" ]]; then
        local domain_count
        domain_count=$(find "$WIKI_ROOT" -maxdepth 2 -name "DOMAIN.md" 2>/dev/null | wc -l | tr -d ' ')
        local doc_count
        doc_count=$(find "$WIKI_ROOT" -name "*.md" -not -path "*/refs/*" 2>/dev/null | wc -l | tr -d ' ')
        success "Wiki exists — $domain_count domain(s), $doc_count pages"
    else
        warn "Wiki directory does not exist. Run: wikimind init"
    fi

    echo ""
    if watcher_running; then
        local pid
        pid=$(cat "$(watcher_pidfile)")
        success "Watcher running (pid $pid)"
    else
        warn "Watcher not running. Run: wikimind start"
    fi

    echo ""
    if check_qmd 2>/dev/null; then
        success "qmd installed"
    else
        warn "qmd not installed — run: pip3 install qmd"
    fi
}

# ── cmd: index ────────────────────────────────────────────────────────────────
cmd_index() {
    if ! check_qmd; then
        exit 1
    fi
    info "Rebuilding search index for: $WIKI_ROOT"
    (cd "$WIKI_ROOT" && qmd index . .) && success "Index rebuilt."
}

# ── Main ──────────────────────────────────────────────────────────────────────
CMD="${1:-help}"
shift || true

case "$CMD" in
    init)    cmd_init "$@" ;;
    start)   cmd_start ;;
    stop)    cmd_stop ;;
    status)  cmd_status ;;
    index)   cmd_index ;;
    help|--help|-h)
        echo ""
        echo "wikimind — WikiMind knowledge base CLI"
        echo ""
        echo "Usage:"
        echo "  wikimind init [PATH]           Create a new wiki (interactive if PATH omitted)"
        echo "  wikimind init [PATH] --adopt   Adopt an existing Markdown directory"
        echo "  wikimind start                 Start the auto-sync watcher"
        echo "  wikimind stop                  Stop the watcher"
        echo "  wikimind status                Show wiki and watcher status"
        echo "  wikimind index                 Rebuild the full search index"
        echo ""
        echo "Environment:"
        echo "  WIKIMIND_ROOT   Path to your wiki directory (default: ~/Documents/wiki)"
        echo ""
        ;;
    *)
        error "Unknown command: $CMD"
        echo "Run 'wikimind help' for usage."
        exit 1
        ;;
esac
